# Project rules for commands that request execution outside the sandbox.

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Reading git status is safe.",
    match = ["git status", "git status --short"],
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Reading git diffs is safe.",
    match = ["git diff", "git diff --stat"],
)

prefix_rule(
    pattern = ["git", "reset"],
    decision = "forbidden",
    justification = "Never reset user work without an explicit request.",
    match = ["git reset --hard", "git reset HEAD~1"],
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "forbidden",
    justification = "Never delete untracked files without an explicit request.",
    match = ["git clean -fd", "git clean -fdx"],
)
